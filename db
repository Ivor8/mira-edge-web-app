--
-- Triggers `project_milestones`
--
DELIMITER $$
CREATE TRIGGER `update_project_completion` AFTER UPDATE ON `project_milestones` FOR EACH ROW BEGIN
    DECLARE total_milestones INT;
    DECLARE completed_milestones INT;
    DECLARE project_completion INT;
    
    IF NEW.is_completed != OLD.is_completed THEN
        SELECT COUNT(*), SUM(CASE WHEN is_completed = 1 THEN 1 ELSE 0 END)
        INTO total_milestones, completed_milestones
        FROM project_milestones
        WHERE internal_project_id = NEW.internal_project_id;
        
        IF total_milestones > 0 THEN
            SET project_completion = ROUND((completed_milestones / total_milestones) * 100);
            
            -- Update main project if all milestones are completed
            IF project_completion = 100 THEN
                UPDATE internal_projects 
                SET status = 'completed', completed_date = CURDATE()
                WHERE internal_project_id = NEW.internal_project_id;
            END IF;
        END IF;
    END IF;
END
$$
DELIMITER ;

