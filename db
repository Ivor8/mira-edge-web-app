--
CREATE DEFINER=`root`@`localhost` PROCEDURE `generate_order_number` (OUT `order_num` VARCHAR(50))   BEGIN
    DECLARE prefix VARCHAR(10) DEFAULT 'MIRA-';
    DECLARE year_str VARCHAR(4);
    DECLARE seq_num INT;
    
    SET year_str = YEAR(CURDATE());
    
    -- Get next sequence number for this year
    SELECT COALESCE(MAX(CAST(SUBSTRING(order_number, 12) AS UNSIGNED)), 0) + 1
    INTO seq_num
    FROM service_orders
    WHERE order_number LIKE CONCAT(prefix, year_str, '-%');
    
    SET order_num = CONCAT(prefix, year_str, '-', LPAD(seq_num, 5, '0'));
END$$

